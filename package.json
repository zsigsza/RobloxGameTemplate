{
  "name": "robloxts-game-template",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "trustedDependencies": [
    "husky"
  ],
  "scripts": {
    "eslint": "eslint places/* --max-warnings=0",
    "lint": "eslint places/*",
    "fix": "eslint --fix places/* ",
    "clean": "rm -rf out && find places -type d -name 'out' -exec rm -rf {} +",
    "compile:base": "cd places/base && rbxtsc --verbose",
    "watch:base": "cd places/base && rbxtsc -w --usePolling",
    "build:base": "rojo build -o places/base/build.rbxl places/base",
    "prod:base": "rojo build -o places/base/build.rbxl places/base/production.project.json",
    "extract:base": "lune run extract-models places/base/build.rbxl base",
    "rojo:base": "cd places/base && rojo serve",
    "test:base": "bun clean && bun compile:base && bun build:base && bun extract:base && lune run client-tests places/base/build.rbxl && lune run server-tests places/base/build.rbxl && lune run client-tests places/base/build.rbxl"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "type-enum": [
        2,
        "always",
        [
          "build",
          "chore",
          "ci",
          "docs",
          "feat",
          "fix",
          "perf",
          "refactor",
          "revert",
          "style",
          "test",
          "deps",
          "core",
          "conf"
        ]
      ]
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@cspell/eslint-plugin": "^8.19.4",
    "@isentinel/dict-rbxts": "^1.0.4",
    "@isentinel/dict-roblox": "^1.0.4",
    "@rbxts/compiler-types": "^2.3.0-types.2",
    "@rbxts/types": "^1.0.915",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-naming": "^0.1.10",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-roblox-ts": "^0.0.36",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "rbxts-transformer-access": "^1.1.2",
    "rbxts-transformer-flamework": "^1.3.2",
    "rbxts-transformer-services": "^1.1.1",
    "roblox-ts": "^3.0.0",
    "typescript": "=5.5.3"
  },
  "dependencies": {
    "@flamework/components": "1.3.1",
    "@flamework/core": "^1.3.2",
    "@rbxts/centurion": "^1.0.1",
    "@rbxts/centurion-ui": "^1.0.8",
    "@rbxts/colour-utils": "^1.4.1",
    "@rbxts/document-service": "^1.2.2-ts.1",
    "@rbxts/make": "^1.0.6",
    "@rbxts/net": "^3.0.10",
    "@rbxts/pretty-react-hooks": "^0.6.4",
    "@rbxts/react": "^17.3.7-ts.1",
    "@rbxts/react-devtools-core": "^17.3.7-ts.1",
    "@rbxts/react-globals": "^17.3.7-ts.1",
    "@rbxts/react-reflex": "^0.3.7",
    "@rbxts/react-roblox": "^17.3.7-ts.1",
    "@rbxts/reflex": "^4.3.1",
    "@rbxts/services": "^1.6.0",
    "@rbxts/sift": "^0.0.11",
    "@rbxts/sound-manager": "^2.3.4",
    "@rbxts/spring": "^1.0.2",
    "@rbxts/string-utils": "^1.0.3",
    "@rbxts/t": "^3.2.1",
    "@rbxts/testez": "^0.4.2-ts.0",
    "@rbxts/trove": "^1.3.0",
    "@rbxts/ui-labs": "^2.4.2",
    "@rbxts/volume3": "^1.0.3"
  }
}